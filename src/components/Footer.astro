---
import { SITE_AUTHOR, SITE_EMAIL, SITE_GITHUB, SITE_LINKEDIN } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<span class="footer-logo">✦ {SITE_AUTHOR}</span>
			<p class="footer-tagline">Game Developer & Creative Technologist</p>
		</div>
		<div class="footer-links">
			<a href="/">Home</a>
			<a href="/about">About</a>
			<a href="/projects">Projects</a>
			<a href="/experience">Experience</a>
			<a href="/education">Education</a>
		</div>
		<div class="footer-social">
			<a href={SITE_GITHUB} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
				</svg>
			</a>
			<a href={SITE_LINKEDIN} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
					<path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/>
				</svg>
			</a>
		</div>
	</div>
	<div class="footer-bottom">
		<p>&copy; {today.getFullYear()} {SITE_AUTHOR}. All rights reserved.</p>
	</div>
</footer>

<style>
	footer {
		background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
		color: rgba(255, 255, 255, 0.8);
		margin-top: 4em;
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		padding: 3em 1.5em 2em;
		display: grid;
		grid-template-columns: 1fr auto auto;
		align-items: center;
		gap: 2em;
	}

	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.25em;
	}

	.footer-logo {
		font-weight: 700;
		font-size: 1.1em;
		background: linear-gradient(135deg, #FFB800, #FF5E8A);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.footer-tagline {
		margin: 0;
		font-size: 0.8em;
		opacity: 0.5;
	}

	.footer-links {
		display: flex;
		gap: 1.25em;
	}

	.footer-links a {
		color: rgba(255, 255, 255, 0.6);
		text-decoration: none;
		font-size: 0.9em;
		transition: color 0.2s;
	}

	.footer-links a:hover {
		color: #FFB800;
	}

	.footer-social {
		display: flex;
		gap: 0.75em;
		align-items: center;
	}

	.footer-social a {
		display: flex;
		color: rgba(255, 255, 255, 0.5);
		text-decoration: none;
		transition: color 0.2s, transform 0.2s;
	}

	.footer-social a:hover {
		color: #FF5E8A;
		transform: translateY(-2px);
	}

	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.25em 1.5em;
	}

	.footer-bottom p {
		margin: 0;
		font-size: 0.8em;
		opacity: 0.4;
		text-align: center;
	}

	@media (max-width: 720px) {
		.footer-inner {
			grid-template-columns: 1fr;
			gap: 1.5em;
		}
		.footer-links {
			flex-wrap: wrap;
			gap: 0.75em;
		}
	}
</style>
