---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'projects'>['data'] & { id: string };

const { title, description, pubDate, coverImage, tech, genre, liveUrl, githubUrl, youtubeId, media, status, id } =
	Astro.props;

const statusStyles: Record<string, { color: string; bg: string; label: string }> = {
	completed: { color: '#3DB553', bg: 'rgba(61,181,83,0.1)', label: 'Completed' },
	'in-progress': { color: '#5B7FD4', bg: 'rgba(91,127,212,0.1)', label: 'In Progress' },
	archived: { color: '#999', bg: 'rgba(0,0,0,0.06)', label: 'Archived' },
};

const s = statusStyles[status ?? 'completed'];

// Build the effective media list for the carousel
type MediaItem =
	| { kind: 'youtube'; src: string }
	| { kind: 'image'; src: string }
	| { kind: 'image-astro'; img: NonNullable<typeof coverImage> };

const effectiveMedia: MediaItem[] = media?.length
	? media.map((m) =>
			m.type === 'youtube'
				? { kind: 'youtube', src: m.src }
				: { kind: 'image', src: m.src }
		)
	: youtubeId
		? [{ kind: 'youtube', src: youtubeId }]
		: coverImage
			? [{ kind: 'image-astro', img: coverImage }]
			: [];

const hasMultiple = effectiveMedia.length > 1;
---

<html lang="en">
	<head>
		<BaseHead title={`${title} - ${SITE_TITLE}`} description={description} />
	</head>
	<body>
		<div class="page-blobs">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
			<div class="blob blob-3"></div>
			<div class="blob blob-4"></div>
			<div class="blob blob-5"></div>
			<div class="blob blob-6"></div>
		</div>
		<Header />

		<main>
			<!-- Carousel Hero -->
			{effectiveMedia.length > 0 && (
				<div class="project-carousel" id="project-carousel">
					<div class="carousel-track" id="carousel-track">
						{effectiveMedia.map((item, i) => (
							<div class="carousel-item" data-index={i}>
								{item.kind === 'youtube' ? (
									<iframe
										src={`https://www.youtube.com/embed/${item.src}`}
										title={`${title} - slide ${i + 1}`}
										allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
										allowfullscreen
									></iframe>
								) : item.kind === 'image-astro' ? (
									<Image width={1100} height={500} src={item.img} alt={`${title}`} />
								) : (
									<img src={item.src} alt={`${title} - screenshot ${i + 1}`} loading="lazy" />
								)}
							</div>
						))}
					</div>

					{hasMultiple && (
						<>
							<button class="carousel-btn carousel-prev" id="carousel-prev" aria-label="Previous slide">&#8249;</button>
							<button class="carousel-btn carousel-next" id="carousel-next" aria-label="Next slide">&#8250;</button>
							<div class="carousel-dots" id="carousel-dots">
								{effectiveMedia.map((_, i) => (
									<button
										class={`dot${i === 0 ? ' active' : ''}`}
										data-index={i}
										aria-label={`Go to slide ${i + 1}`}
									></button>
								))}
							</div>
						</>
					)}
				</div>
			)}

			<div class="project-layout">
				<!-- Main Content -->
				<article class="project-content">
					<div class="project-header">
						<a href="/projects" class="back-link">← All Projects</a>
						<div class="project-badges">
							{genre && <span class="genre-badge">{genre}</span>}
							<span class="status-badge" style={`color: ${s.color}; background: ${s.bg};`}>{s.label}</span>
						</div>
						<h1 class="project-title">{title}</h1>
						<p class="project-description">{description}</p>
					</div>

					<div class="prose">
						<slot />
					</div>
				</article>

				<!-- Sidebar -->
				<aside class="project-sidebar">
					<!-- Links -->
					{(liveUrl || githubUrl) && (
						<div class="sidebar-card">
							<h3 class="sidebar-title">Links</h3>
							<div class="sidebar-links">
								{liveUrl && (
									<a href={liveUrl} target="_blank" rel="noopener noreferrer" class="sidebar-link primary">
										<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
											<circle cx="12" cy="12" r="10"></circle>
											<line x1="2" y1="12" x2="22" y2="12"></line>
											<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
										</svg>
										Live Demo / Play
									</a>
								)}
								{githubUrl && (
									<a href={githubUrl} target="_blank" rel="noopener noreferrer" class="sidebar-link secondary">
										<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
											<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
										</svg>
										Source Code
									</a>
								)}
							</div>
						</div>
					)}

					<!-- Tech Stack -->
					{tech && tech.length > 0 && (
						<div class="sidebar-card">
							<h3 class="sidebar-title">Tech Stack</h3>
							<div class="tech-list">
								{tech.map((t) => (
									<span class="tech-item">{t}</span>
								))}
							</div>
						</div>
					)}

					<!-- Details -->
					<div class="sidebar-card">
						<h3 class="sidebar-title">Details</h3>
						<dl class="detail-list">
							<dt>Status</dt>
							<dd style={`color: ${s.color};`}>{s.label}</dd>
							{genre && (
								<>
									<dt>Genre</dt>
									<dd>{genre}</dd>
								</>
							)}
							<dt>Date</dt>
							<dd>{pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</dd>
						</dl>
					</div>

					<a href="/projects" class="back-btn">← Back to Projects</a>
				</aside>
			</div>
		</main>

		<Footer />
	</body>
</html>

<style>
	body { position: relative; }

	section, main, header, footer, article, aside { position: relative; z-index: 1; }

	.page-blobs {
		position: absolute;
		inset: 0;
		pointer-events: none;
		z-index: 0;
		overflow: hidden;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(110px);
		opacity: 0.18;
		animation: float 8s ease-in-out infinite;
	}
	.blob-1 { width: 600px; height: 600px; background: #FFB800; top: -200px; right: -80px; animation-delay: 0s; }
	.blob-2 { width: 400px; height: 400px; background: #FF5E8A; top: 10%; left: -100px; animation-delay: -3s; }
	.blob-3 { width: 500px; height: 500px; background: #5B7FD4; top: 35%; right: -80px; animation-delay: -5s; }
	.blob-4 { width: 350px; height: 350px; background: #FFB800; top: 55%; left: -60px; animation-delay: -2s; }
	.blob-5 { width: 450px; height: 450px; background: #FF5E8A; top: 72%; right: 5%; animation-delay: -6s; }
	.blob-6 { width: 300px; height: 300px; background: #3DB553; top: 88%; left: 20%; animation-delay: -4s; }

	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-20px); }
	}

	main {
		max-width: 1350px;
		margin: 0 auto;
		padding: 0 1.5em 5em;
		width: 100%;
		box-sizing: border-box;
	}

	/* ── Carousel ── */
	.project-carousel {
		position: relative;
		width: calc(100% + 3em);
		margin-left: -1.5em;
		margin-right: -1.5em;
		margin-bottom: 3em;
		height: 480px;
		overflow: hidden;
		border-radius: 0 0 20px 20px;
		background: rgb(15, 18, 25);
	}

	.carousel-track {
		display: flex;
		height: 100%;
		transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
		will-change: transform;
	}

	.carousel-item {
		flex: 0 0 100%;
		height: 100%;
		overflow: hidden;
	}

	.carousel-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.carousel-item iframe {
		width: 100%;
		height: 100%;
		border: none;
		display: block;
	}

	.carousel-btn {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		background: rgba(0, 0, 0, 0.55);
		color: white;
		border: none;
		border-radius: 50%;
		width: 48px;
		height: 48px;
		font-size: 1.8em;
		line-height: 1;
		cursor: pointer;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.2s, transform 0.2s;
		backdrop-filter: blur(4px);
	}

	.carousel-btn:hover {
		background: rgba(0, 0, 0, 0.8);
		transform: translateY(-50%) scale(1.08);
	}

	.carousel-prev { left: 1em; }
	.carousel-next { right: 1em; }

	.carousel-dots {
		position: absolute;
		bottom: 1em;
		left: 50%;
		transform: translateX(-50%);
		display: flex;
		gap: 0.5em;
		z-index: 10;
	}

	.dot {
		width: 9px;
		height: 9px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.45);
		border: none;
		cursor: pointer;
		padding: 0;
		transition: background 0.2s, transform 0.2s;
	}

	.dot:hover { background: rgba(255, 255, 255, 0.75); }
	.dot.active {
		background: white;
		transform: scale(1.25);
	}

	/* ── Layout ── */
	.project-layout {
		display: grid;
		grid-template-columns: 1fr 140px;
		gap: 3em;
		align-items: start;
	}

	/* Header */
	.project-header {
		margin-bottom: 2em;
	}

	.back-link {
		display: inline-block;
		color: rgb(96, 115, 159);
		text-decoration: none;
		font-size: 0.88em;
		font-weight: 500;
		margin-bottom: 1em;
		transition: color 0.2s;
	}
	.back-link:hover { color: #FF6200; }

	.project-badges {
		display: flex;
		gap: 0.5em;
		margin-bottom: 0.75em;
		flex-wrap: wrap;
	}

	.genre-badge {
		font-size: 0.78em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #5B7FD4;
		background: rgba(91,127,212,0.1);
		padding: 0.2em 0.75em;
		border-radius: 6px;
	}

	.status-badge {
		font-size: 0.78em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.2em 0.75em;
		border-radius: 6px;
	}

	.project-title {
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0 0 0.4em;
		line-height: 1.1;
	}

	.project-description {
		font-size: 1.1em;
		color: rgb(96, 115, 159);
		margin: 0;
		line-height: 1.55;
	}

	.project-divider {
		border: none;
		height: 2px;
		background: #4a4a4a;
		margin: 2em 0 2.5em;
	}

	/* Prose */
	.prose {
		font-size: 1.05em;
		line-height: 1.8;
		color: rgb(34, 41, 57);
	}

	.prose :global(.video-embed) {
		position: relative;
		padding-bottom: 56.25%;
		height: 0;
		overflow: hidden;
		border-radius: 12px;
		margin: 1.5em 0;
		background: rgb(15,18,25);
	}

	.prose :global(.video-embed iframe) {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: none;
		border-radius: 12px;
	}

	.prose :global(h2) {
		font-size: 1.5em;
		margin: 2em 0 0.6em;
		padding-bottom: 0.3em;
		border-bottom: 2px solid #4a4a4a;
	}

	.prose :global(h3) {
		font-size: 1.2em;
		margin: 1.5em 0 0.4em;
		color: #FF6200;
	}

	.prose :global(a) { color: #5B7FD4; }
	.prose :global(a:hover) { color: #FF5E8A; }

	.prose :global(ul), .prose :global(ol) {
		padding-left: 1.5em;
		margin: 1em 0;
	}

	.prose :global(li) { margin-bottom: 0.4em; }

	.prose :global(strong) { color: rgb(15,18,25); }

	.prose :global(code) {
		background: rgba(91,127,212,0.1);
		color: #5B7FD4;
		padding: 0.15em 0.4em;
		border-radius: 4px;
		font-size: 0.88em;
	}

	.prose :global(pre) {
		background: rgb(15,18,25);
		border-radius: 12px;
		padding: 1.5em;
		overflow-x: auto;
		margin: 1.5em 0;
	}

	.prose :global(pre code) {
		background: none;
		color: #e8eaf0;
		padding: 0;
		font-size: 0.9em;
	}

	/* Sidebar */
	.project-sidebar {
		position: sticky;
		top: 80px;
		display: flex;
		flex-direction: column;
		gap: 0.75em;
	}

	.sidebar-card {
		background: white;
		border: 2px solid #FFB800;
		border-radius: 12px;
		padding: 0.9em;
		box-shadow: 0 2px 8px rgba(0,0,0,0.04);
	}

	.sidebar-title {
		font-size: 0.65em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(96,115,159);
		margin: 0 0 0.75em;
	}

	.sidebar-links {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}

	.sidebar-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.4em;
		padding: 0.55em 0.5em;
		border-radius: 8px;
		text-decoration: none;
		font-size: 0.72em;
		font-weight: 600;
		transition: transform 0.2s, box-shadow 0.2s;
		text-align: center;
	}

	.sidebar-link.primary {
		background: #FFB800;
		color: #1a1a1a;
		box-shadow: 0 3px 12px rgba(255,184,0,0.3);
	}

	.sidebar-link.primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(255,184,0,0.4);
		color: #1a1a1a;
	}

	.sidebar-link.secondary {
		background: rgba(0,0,0,0.05);
		color: rgb(34,41,57);
		border: 1px solid rgba(0,0,0,0.08);
	}

	.sidebar-link.secondary:hover {
		background: rgba(0,0,0,0.08);
		color: rgb(15,18,25);
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
	}

	.tech-item {
		background: rgba(255,184,0,0.1);
		color: #cc7700;
		border-radius: 5px;
		padding: 0.2em 0.5em;
		font-size: 0.68em;
		font-weight: 600;
	}

	.detail-list {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		margin: 0;
		font-size: 0.72em;
	}

	.detail-list dt {
		color: rgb(96,115,159);
		font-weight: 500;
		font-size: 0.85em;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.detail-list dd {
		margin: 0 0 0.25em;
		font-weight: 600;
		color: rgb(15,18,25);
	}

	.back-btn {
		display: inline-flex;
		align-items: center;
		background: rgba(0,0,0,0.04);
		color: rgb(34,41,57);
		font-weight: 600;
		padding: 0.55em 0.75em;
		border-radius: 8px;
		text-decoration: none;
		font-size: 0.72em;
		transition: background 0.2s;
		text-align: center;
		justify-content: center;
	}

	.back-btn:hover {
		background: rgba(255,184,0,0.1);
		color: #cc7700;
	}

	@media (max-width: 800px) {
		.project-carousel { height: 260px; }
		.project-layout { grid-template-columns: 1fr; }
		.project-sidebar {
			position: static;
			display: grid;
			grid-template-columns: repeat(2, 1fr);
		}
		.back-btn { grid-column: span 2; }
	}

	@media (max-width: 500px) {
		.project-carousel { height: 210px; }
		.carousel-btn { width: 36px; height: 36px; font-size: 1.4em; }
		.project-sidebar { grid-template-columns: 1fr; }
		.back-btn { grid-column: span 1; }
	}
</style>

<script is:inline>
	(function () {
		const carousel = document.getElementById('project-carousel');
		if (!carousel) return;
		const track = document.getElementById('carousel-track');
		const dots = Array.from(carousel.querySelectorAll('.dot'));
		const prev = document.getElementById('carousel-prev');
		const next = document.getElementById('carousel-next');
		if (!track) return;

		const itemCount = track.querySelectorAll('.carousel-item').length;
		let current = 0;

		function goTo(index) {
			current = ((index % itemCount) + itemCount) % itemCount;
			track.style.transform = 'translateX(-' + (current * 100) + '%)';
			dots.forEach(function (d, i) {
				d.classList.toggle('active', i === current);
			});
		}

		if (prev) prev.addEventListener('click', function () { goTo(current - 1); });
		if (next) next.addEventListener('click', function () { goTo(current + 1); });
		dots.forEach(function (dot, i) {
			dot.addEventListener('click', function () { goTo(i); });
		});

		// Swipe support
		var startX = 0;
		carousel.addEventListener('touchstart', function (e) { startX = e.touches[0].clientX; }, { passive: true });
		carousel.addEventListener('touchend', function (e) {
			var diff = startX - e.changedTouches[0].clientX;
			if (Math.abs(diff) > 40) goTo(diff > 0 ? current + 1 : current - 1);
		});

		// Keyboard arrow support
		document.addEventListener('keydown', function (e) {
			if (e.key === 'ArrowLeft') goTo(current - 1);
			if (e.key === 'ArrowRight') goTo(current + 1);
		});
	})();
</script>
