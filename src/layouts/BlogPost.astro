---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />

		<div class="post-accent-bar"></div>

		<main>
			<article>
				<!-- Hero Image -->
				{heroImage && (
					<div class="hero-image">
						<Image width={1100} height={500} src={heroImage} alt={title} />
					</div>
				)}

				<!-- Post Header -->
				<header class="post-header">
					<div class="post-meta-top">
						<a href="/blog" class="back-link">← Back to Blog</a>
						{tags && tags.length > 0 && (
							<div class="post-tags">
								{tags.map((tag) => (
									<a href={`/tags/${tag}`} class="tag">{tag}</a>
								))}
							</div>
						)}
					</div>

					<h1 class="post-title">{title}</h1>
					<p class="post-description">{description}</p>

					<div class="post-meta">
						<div class="meta-item">
							<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
								<line x1="16" y1="2" x2="16" y2="6"></line>
								<line x1="8" y1="2" x2="8" y2="6"></line>
								<line x1="3" y1="10" x2="21" y2="10"></line>
							</svg>
							<FormattedDate date={pubDate} />
						</div>
						{updatedDate && (
							<div class="meta-item updated">
								<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<polyline points="23 4 23 10 17 10"></polyline>
									<path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
								</svg>
								Updated <FormattedDate date={updatedDate} />
							</div>
						)}
					</div>
				</header>

				<hr class="post-divider" />

				<!-- Post Content -->
				<div class="prose">
					<slot />
				</div>

				<!-- Post Footer -->
				<footer class="post-footer">
					{tags && tags.length > 0 && (
						<div class="post-footer-tags">
							<span class="footer-tag-label">Tagged:</span>
							{tags.map((tag) => (
								<a href={`/tags/${tag}`} class="footer-tag">{tag}</a>
							))}
						</div>
					)}
					<div class="post-nav">
						<a href="/blog" class="btn-back">← All Posts</a>
					</div>
				</footer>
			</article>
		</main>

		<Footer />
	</body>
</html>

<style>
	.post-accent-bar {
		height: 5px;
		background: linear-gradient(90deg, #FFB800, #FF5E8A, #FF6200, #5B7FD4, #3DB553);
		background-size: 200% 100%;
		animation: gradientShift 4s ease infinite;
	}

	main {
		max-width: 780px;
		margin: 0 auto;
		padding: 3em 1.5em 5em;
	}

	.hero-image {
		width: calc(100% + 3em);
		margin-left: -1.5em;
		margin-right: -1.5em;
		margin-bottom: 2.5em;
		overflow: hidden;
		border-radius: 0 0 20px 20px;
	}

	.hero-image img {
		width: 100%;
		height: 420px;
		object-fit: cover;
		border-radius: 0 0 20px 20px;
		display: block;
	}

	.post-header { margin-bottom: 2em; }

	.post-meta-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1.25em;
		flex-wrap: wrap;
		gap: 0.75em;
	}

	.back-link {
		color: rgb(96, 115, 159);
		text-decoration: none;
		font-size: 0.88em;
		font-weight: 500;
		transition: color 0.2s;
	}

	.back-link:hover { color: #FF6200; }

	.post-tags {
		display: flex;
		gap: 0.4em;
		flex-wrap: wrap;
	}

	.tag {
		display: inline-block;
		background: rgba(91, 127, 212, 0.1);
		color: #5B7FD4;
		border-radius: 8px;
		padding: 0.2em 0.75em;
		font-size: 0.78em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		text-decoration: none;
		transition: background 0.2s, color 0.2s;
	}

	.tag:hover {
		background: #5B7FD4;
		color: white;
	}

	.post-title {
		font-size: clamp(2rem, 5vw, 3rem);
		line-height: 1.15;
		margin: 0 0 0.5em;
		color: rgb(15, 18, 25);
	}

	.post-description {
		font-size: 1.15em;
		color: rgb(96, 115, 159);
		margin: 0 0 1.25em;
		line-height: 1.5;
	}

	.post-meta {
		display: flex;
		gap: 1.5em;
		flex-wrap: wrap;
	}

	.meta-item {
		display: flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.88em;
		color: rgb(96, 115, 159);
	}

	.meta-item.updated { font-style: italic; }

	.post-divider {
		border: none;
		height: 2px;
		background: linear-gradient(90deg, #FFB800, #FF5E8A, transparent);
		margin: 0 0 2.5em;
	}

	/* Prose styles */
	.prose {
		font-size: 1.05em;
		line-height: 1.8;
		color: rgb(34, 41, 57);
	}

	.prose :global(h2) {
		font-size: 1.6em;
		margin: 2em 0 0.6em;
		padding-bottom: 0.3em;
		border-bottom: 2px solid rgba(255, 184, 0, 0.3);
	}

	.prose :global(h3) {
		font-size: 1.25em;
		margin: 1.5em 0 0.5em;
		color: #FF6200;
	}

	.prose :global(a) {
		color: #5B7FD4;
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.prose :global(a:hover) { color: #FF5E8A; }

	.prose :global(blockquote) {
		border-left: 4px solid #FFB800;
		background: rgba(255, 184, 0, 0.05);
		padding: 0.75em 1.25em;
		margin: 1.5em 0;
		border-radius: 0 8px 8px 0;
		font-style: italic;
	}

	.prose :global(code) {
		background: rgba(91, 127, 212, 0.1);
		color: #5B7FD4;
		padding: 0.15em 0.4em;
		border-radius: 4px;
		font-size: 0.88em;
	}

	.prose :global(pre) {
		background: rgb(15, 18, 25);
		border-radius: 12px;
		padding: 1.5em;
		overflow-x: auto;
		margin: 1.5em 0;
	}

	.prose :global(pre code) {
		background: none;
		color: #e8eaf0;
		padding: 0;
		font-size: 0.9em;
	}

	.prose :global(img) {
		border-radius: 12px;
		box-shadow: 0 8px 30px rgba(0, 0, 0, 0.1);
		margin: 1.5em 0;
	}

	/* Post Footer */
	.post-footer {
		margin-top: 4em;
		padding-top: 2em;
		border-top: 1px solid rgba(0, 0, 0, 0.08);
	}

	.post-footer-tags {
		display: flex;
		align-items: center;
		gap: 0.5em;
		flex-wrap: wrap;
		margin-bottom: 1.5em;
	}

	.footer-tag-label {
		font-size: 0.85em;
		color: rgb(96, 115, 159);
		font-weight: 600;
	}

	.footer-tag {
		display: inline-block;
		background: rgba(255, 184, 0, 0.1);
		color: #cc7700;
		border-radius: 8px;
		padding: 0.2em 0.75em;
		font-size: 0.82em;
		font-weight: 600;
		text-decoration: none;
		border: 1px solid rgba(255, 184, 0, 0.2);
		transition: all 0.2s;
	}

	.footer-tag:hover {
		background: #FFB800;
		color: #1a1a1a;
		border-color: #FFB800;
	}

	.post-nav { margin-top: 1.5em; }

	.btn-back {
		display: inline-flex;
		align-items: center;
		background: rgba(0, 0, 0, 0.04);
		color: rgb(34, 41, 57);
		font-weight: 600;
		padding: 0.65em 1.4em;
		border-radius: 10px;
		text-decoration: none;
		font-size: 0.9em;
		transition: background 0.2s, color 0.2s;
	}

	.btn-back:hover {
		background: rgba(255, 184, 0, 0.12);
		color: #cc7700;
	}

	@media (max-width: 600px) {
		.hero-image {
			width: calc(100% + 3em);
			margin-left: -1.5em;
		}
		.hero-image img { height: 240px; }
	}
</style>
